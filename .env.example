# =====================================================================
# Environment Configuration Template
# Copy this file to .env and fill in the appropriate values
# =====================================================================

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aeterna_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aeterna_db

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_password

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT & Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=AETERNA

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Celery Configuration
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379

# Blockchain/Web3 Configuration (On-Chain Collector)
# QuickNode, Alchemy, or Infura endpoint for Ethereum mainnet
# Example services:
#   - QuickNode: https://www.quicknode.com/
#   - Alchemy: https://www.alchemy.com/
#   - Infura: https://infura.io/
# Use WebSocket (wss://) endpoints for real-time event monitoring
QUICKNODE_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Third-party Integrations (Optional)
# Add any additional API keys or service credentials here
