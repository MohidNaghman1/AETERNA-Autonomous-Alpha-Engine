# =====================================================================
# EXAMPLE: How to store wallets in .env file
# Copy the wallet entries to your actual .env file
# =====================================================================

# ============================================================================
# EXCHANGE WALLETS (Known exchanges to track)
# ============================================================================

# Format: JSON array with address and name
# - address: lowercase Ethereum address (required)
# - name: human-readable exchange name (required)
# 
# Example:
EXCHANGE_WALLETS_JSON='[
  {
    "address": "0x3f5ce5fbfe3e9af3971dd833d97da793a8eb06f7",
    "name": "Binance"
  },
  {
    "address": "0x1688a1c8f3b10b2cfbbf9b1cccc09d8c7ba8d79e",
    "name": "Binance"
  },
  {
    "address": "0xeb1aef396a02aa67d4bb4cea1847fb0a7b682a24",
    "name": "Bitfinex"
  },
  {
    "address": "0x2f3ab9fd633e34c2db4b9c0d1e15ae47f8a2a2e8",
    "name": "Kraken"
  },
  {
    "address": "0xfe854845c1f59a64ab9d0ff266ffdb565106b5ca",
    "name": "OpenSea"
  }
]'

# ============================================================================
# WHALE WALLETS (High-value individual/entities to track)
# ============================================================================

# Format: JSON array with address, name, and tier
# - address: lowercase Ethereum address (required)
# - name: entity name (required) 
# - tier: performance tier (optional) - one of:
#         "high_performer" (85%+ win rate)
#         "medium_performer" (50-84% win rate)
#         "unknown" (unverified)
#
# Example:
WHALE_WALLETS_JSON='[
  {
    "address": "0x7a9f47a94f37e828fe5ab03f2e0199880e6b0b0e",
    "name": "Andreessen Horowitz",
    "tier": "high_performer"
  },
  {
    "address": "0x1111111111111111111111111111111111111111",
    "name": "Paradigm Capital",
    "tier": "high_performer"
  },
  {
    "address": "0x2222222222222222222222222222222222222222",
    "name": "Unknown Whale 1",
    "tier": "unknown"
  }
]'

# ============================================================================
# VC FUND WALLETS (Venture capital firms)
# ============================================================================

# Format: JSON array with address, name, and confidence
# - address: lowercase Ethereum address (required)
# - name: VC fund name (required)
# - confidence: confidence score 0.0-1.0 (optional)
#               1.0 = 100% sure this is the VC fund
#               0.9 = 90% sure, etc.
#
# Example:
VC_FUND_WALLETS_JSON='[
  {
    "address": "0x7a9f47a94f37e828fe5ab03f2e0199880e6b0b0e",
    "name": "Andreessen Horowitz Fund III",
    "confidence": 0.95
  },
  {
    "address": "0x3333333333333333333333333333333333333333",
    "name": "Polychain Capital",
    "confidence": 0.90
  }
]'

# ============================================================================
# HOW THE ON-CHAIN COLLECTOR WILL USE THESE:
# ============================================================================

# 1. EXCHANGE_WALLETS_JSON is used to detect exchange movements:
#    When wallet 0x3f5ce... moves $10M to Binance
#    → System knows this is Binance
#    → Marks as exchange activity
#
# 2. WHALE_WALLETS_JSON is used for Agent B profiling:
#    When wallet 0x7a9f... moves $50M
#    → Agent B checks: "Do I know this wallet?"
#    → If tier="high_performer", boost the alert priority
#    → Score it as HIGH priority signal
#
# 3. VC_FUND_WALLETS_JSON is used for entity attribution:
#    When news says "Andreessen Horowitz invests in XYZ"
#    → System looks up A16Z wallets from this config
#    → Links on-chain activity to entity name
#    → Enriches alerts with VC fund context
